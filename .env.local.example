# ShipSignal — local development environment variables
# Copy to .env.local, fill in your values, then run: npm run dev

# Required: AI provider key (or leave blank if using github-copilot with GITHUB_TOKEN)
AI_API_KEY=your-api-key-here

# Required: tells ShipSignal which deploy point to use
DEPLOY_ENVIRONMENT=production

# Optional: comma-separated override (default: whatever the deploy_point configures)
# PERSONA_OVERRIDE=executive,end-user

# Jira (optional — skip if you don't have Jira or want to test without it)
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_USER_EMAIL=you@yourorg.com
JIRA_API_TOKEN=your-jira-api-token

# GitHub (optional — used to fetch PR description; fine to leave blank locally)
GITHUB_TOKEN=
GH_REPOSITORY=yourorg/yourrepo
PR_NUMBER=
GH_SHA=abc1234deadbeef
GH_REF_NAME=main

# ShipSignal internals
DRY_RUN=true
