{
  "name": "legibly-action",
  "version": "1.0.0",
  "description": "Translates engineering deployments into value-focused release notes",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "npm run build && node -r dotenv/config dist/index.js dotenv_config_path=../.env.local",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "mcp": "node dist/mcp.js",
    "mcp:dev": "npm run build && node dist/mcp.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "~0.39.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "js-yaml": "~4.1.0",
    "openai": "~4.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "dotenv": "^16.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
